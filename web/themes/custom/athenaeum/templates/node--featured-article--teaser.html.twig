{%
  set classes = [
    'article-card',
    'node--teaser',
  ]
%}
<article{{ attributes.addClass(classes) }}>

  {% if content.field_image %}
    <a href="{{ url }}" tabindex="-1" aria-hidden="true">
      {{ content.field_image }}
    </a>
  {% else %}
    <a href="{{ url }}" class="article-card__image-placeholder" tabindex="-1" aria-hidden="true">
      📜
    </a>
  {% endif %}

  <div class="article-card__body">
    <h3 class="article-card__title">
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h3>

    {% if node.field_lead.value %}
      <div class="article-card__lead">{{ node.field_lead.value|striptags|truncate(160, true, '…') }}</div>
    {% elseif content.body %}
      <div class="article-card__lead">{{ content.body|render|striptags|truncate(160, true, '…') }}</div>
    {% endif %}

    <div class="article-card__meta">
      {% for topic in node.field_topics %}
        <span class="topic-badge">{{ topic.entity.name.value }}</span>
      {% endfor %}
    </div>
  </div>

</article>
