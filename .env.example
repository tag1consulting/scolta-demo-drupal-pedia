# The Athenaeum — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Required only for AI enrichment pass (drush athenaeum:enrich)
# Not needed at runtime — enrichment runs at build time only.
ANTHROPIC_API_KEY=

# Scolta API key (injected via .ddev/config.local.yaml)
SCOLTA_API_KEY=
