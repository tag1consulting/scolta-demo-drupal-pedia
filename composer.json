{
    "name": "scolta/the-athenaeum",
    "description": "The Athenaeum: Wikipedia Featured Articles encyclopedia showcasing Scolta cross-domain semantic search",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "composer/installers": "^2.0",
        "drupal/core-composer-scaffold": "^11",
        "drupal/core-project-message": "^11",
        "drupal/core-recommended": "^11",
        "drupal/geofield": "^1.0",
        "drupal/pathauto": "^1.12",
        "drupal/search_api": "^1.0",
        "drush/drush": "^13",
        "tag1/scolta-drupal": "0.3.9",
        "tag1/scolta-php": "0.3.9",
        "cweagans/composer-patches": "^1.7"
    },
    "require-dev": {
        "drupal/core-dev": "^11"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "repositories": {
        "drupal": {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "cweagans/composer-patches": true
        },
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "@sync-scolta-assets"
        ],
        "post-update-cmd": [
            "@sync-scolta-assets"
        ],
        "sync-scolta-assets": "@php scripts/sync-scolta-assets.php"
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/profiles/custom/{$name}": [
                "type:drupal-custom-profile"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        },
        "drupal-core-project-message": {
            "include-keys": [
                "homepage",
                "support"
            ],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                              </>",
                "<bg=blue;fg=white>  Congratulations, you've installed The Athenaeum!           </>",
                "<bg=blue;fg=white>  Run `ddev start` to bring up the local environment.        </>",
                "<bg=blue;fg=white>                                                              </>"
            ]
        },
        "composer-exit-on-patch-failure": true,
        "patches": {
            "tag1/scolta-php": {
                "URL normalization and filters support (pending v0.3.10)": "patches/scolta-php-url-and-filters.patch"
            }
        }
    }
}
